# Copy to ".env" and fill in. Never commit .env.
# For EAS production builds, add the same EXPO_PUBLIC_* variables in:
# Expo dashboard → Project → Environment variables (or: eas env:create)

EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_AZURE_SPEECH_KEY=
EXPO_PUBLIC_AZURE_SPEECH_REGION=eastus

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth client IDs (from console.cloud.google.com → APIs & Services → Credentials)
# The "Web" client ID is used by expo-auth-session's ID-token flow (Firebase expects it).
# Android/iOS client IDs are platform-specific OAuth clients matched by package + SHA-1.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
