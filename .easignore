# Same as .gitignore BUT allows secret config files to be uploaded to EAS build servers

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files — `.env` (no suffix) is uploaded to EAS so EXPO_PUBLIC_* vars
# are inlined into the production bundle. Only ignore machine-specific ones.
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# EAS / Play Store secrets (not needed at build time)
play-service-account.json
google-services.json
