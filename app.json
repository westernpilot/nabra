{
  "expo": {
    "name": "Nabra",
    "slug": "nabra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nabra.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Nabra uses your microphone to record Arabic pronunciation for real-time feedback.",
        "NSSpeechRecognitionUsageDescription": "Nabra analyzes your speech to score your Arabic pronunciation."
      }
    },
    "android": {
      "package": "com.nabra.app",
      "versionCode": 19,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "nabra",
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": "Nabra uses your microphone to record Arabic pronunciation for real-time feedback."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0A0A0A"
        }
      ],
      "expo-font",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "51669f04-56b8-4fa9-8e02-5ede48407a4f"
      }
    },
    "owner": "westerne"
  }
}
